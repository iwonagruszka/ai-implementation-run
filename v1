<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Implementation Run — iwonagruszka.com</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-a: #E1CECE;
    --bg-b: #EFE3E3;
    --panel: #FFFFFF;
    --ink: #1A2E2E;
    --ink-soft: #5C6E6E;
    --brand: #036564;
    --brand-dark: #024746;
    --accent: #036564;
    --accent-dark: #024746;
    --gold: #C98B7F;
    --good: #036564;
    --line: #D8C2C2;
    --danger: #B5564C;
    --sky-top: #E1CECE;
    --sky-bottom: #F3E9E9;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    min-height:100vh;
    font-family:'Manrope', sans-serif;
    background:
      radial-gradient(circle at 15% 10%, rgba(255,255,255,.6), transparent 40%),
      linear-gradient(160deg, var(--bg-a), var(--bg-b));
    color:var(--ink);
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:28px 16px 60px;
  }
  .demo-tag{
    font-size:12px; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-soft);
    background:rgba(255,255,255,.7); border:1px solid var(--line);
    padding:6px 14px; border-radius:999px; margin-bottom:18px; font-weight:700;
  }
  .widget{
    width:100%; max-width:460px; background:var(--panel); border-radius:28px;
    box-shadow: 0 30px 60px -25px rgba(3,101,100,.30), 0 2px 0 rgba(255,255,255,.6) inset;
    overflow:hidden; position:relative; min-height:660px; display:flex; flex-direction:column;
  }
  .screen{ padding:26px 24px 24px; display:flex; flex-direction:column; flex:1; animation: fadeIn .35s ease; }
  @keyframes fadeIn{ from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:none;} }

  h1,h2,h3{ font-family:'Baloo 2', sans-serif; margin:0; line-height:1.15; }
  h1{ font-size:25px; font-weight:800; color:var(--brand-dark); }
  h2{ font-size:19px; font-weight:700; color:var(--ink); }
  p{ margin:0; }
  .muted{ color:var(--ink-soft); font-size:13.5px; line-height:1.5; }

  .mascot{ font-size:52px; display:block; text-align:center; margin:4px 0 2px; filter:drop-shadow(0 8px 10px rgba(3,101,100,.25)); }

  .btn{
    appearance:none; border:none; cursor:pointer;
    font-family:'Baloo 2', sans-serif; font-weight:700; font-size:16px;
    padding:13px 20px; border-radius:16px;
    background:var(--accent); color:#fff;
    box-shadow: 0 6px 0 var(--accent-dark);
    transition: transform .08s ease;
  }
  .btn:active{ transform:translateY(4px); box-shadow:0 2px 0 var(--accent-dark); }
  .btn.secondary{ background:#F2E4E4; color:var(--brand-dark); box-shadow:0 6px 0 #D8C2C2; }
  .btn.secondary:active{ box-shadow:0 2px 0 #D8C2C2; }
  .btn:disabled{ opacity:.45; cursor:not-allowed; box-shadow:0 6px 0 rgba(0,0,0,.1); }
  .btn-row{ display:flex; gap:10px; margin-top:auto; padding-top:16px; }
  .btn-row .btn{ flex:1; }

  input[type=text], input[type=email]{
    width:100%; font-family:'Manrope',sans-serif; font-size:15px;
    padding:12px 14px; border-radius:14px; border:2px solid var(--line);
    background:#FBF6F6; color:var(--ink); font-weight:600;
  }
  input:focus{ outline:none; border-color:var(--brand); }
  label{ font-size:13px; font-weight:700; color:var(--ink-soft); display:block; margin:12px 0 6px; }

  .avatar-grid{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; margin-top:6px; }
  .avatar-opt{
    height:48px; font-size:24px; text-align:center; border-radius:14px;
    border:2px solid var(--line); background:#FBF6F6; cursor:pointer;
    display:flex; align-items:center; justify-content:center;
  }
  .avatar-opt.selected{ border-color:var(--brand); background:#DCEDEC; box-shadow:0 0 0 3px rgba(3,101,100,.18); }
  .avatar-opt.img-opt img{ max-height:40px; max-width:34px; width:auto; height:auto; object-fit:contain; display:block; }
  .mascot img{ height:96px; width:auto; display:block; margin:0 auto; filter:drop-shadow(0 8px 10px rgba(3,101,100,.25)); }

  .legend{ display:flex; gap:14px; justify-content:center; margin:10px 0 4px; flex-wrap:wrap; }
  .legend-block{ width:100%; margin:10px 0 2px; }
  .legend-title{ font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.6px; text-align:center; margin-bottom:6px; }
  .legend-title.danger-title{ color:var(--danger); }
  .legend-title.good-title{ color:var(--brand); }
  .legend-grid{ display:flex; flex-wrap:wrap; justify-content:center; gap:6px; }
  .legend-grid span{ display:inline-flex; align-items:center; gap:5px; font-size:11.5px; font-weight:700;
    color:var(--ink-soft); background:#FBF6F6; border:1px solid var(--line);
    padding:4px 9px; border-radius:999px; }
  .legend-grid span i{ font-style:normal; font-size:14px; }
  .legend-grid span b{ color:var(--brand); font-weight:800; }
  .legend span{ font-size:12px; color:var(--ink-soft); font-weight:700; display:flex; align-items:center; gap:4px; }

  /* Gra */
  .hud{ display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
  .hud .coin{ font-family:'Baloo 2',sans-serif; font-weight:800; color:var(--brand-dark); display:flex; align-items:center; gap:6px; font-size:15px; }
