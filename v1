<script>
/* ---------- STATE (in memory, no localStorage) ---------- */
/* =========================================================
   CONFIG — EDIT THESE THREE VALUES BEFORE GOING LIVE
   ---------------------------------------------------------
   MAILCHIMP_ACTION:
     Mailchimp > Audience > Signup forms > Embedded form.
     Copy the <form action="..."> URL and paste it below,
     then change the ending /post?  to  /post-json?
   PRIVACY_URL: link to your privacy policy page.
   IMPORTANT: turn ON double opt-in in Mailchimp audience
   settings. It gives you documented proof of consent.
   ========================================================= */
const CONFIG = {
  MAILCHIMP_ACTION: '', // e.g. 'https://iwonagruszka.us21.list-manage.com/subscribe/post-json?u=XXXX&id=YYYY'
  PRIVACY_URL: 'https://iwonagruszka.com/privacy-policy',
  ASSESSMENT_URL: 'https://goals.iwonagruszka.com/',
  COMPANY: 'iwonagruszka.com',
};

const CYBORG_KEY = 'cyborg';
const CYBORG_SRC = "data:image/png;base64,";
const cyborgImg = new Image();
cyborgImg.src = CYBORG_SRC;

const state = {
  screen: 'start',
  nick: '',
  avatar: CYBORG_KEY,
  email: '',
  score: 0,
  _saved: false,
  consentPrivacy: false,   // required: terms + privacy policy
  consentMarketing: false, // optional: marketing e-mails
  consentTextShown: '',    // stored as proof of what was agreed to
  consentTimestamp: '',
};

const AVATARS = ['🦊','🦉','🐼','🐸','🦄','🐻','🐧','🦁','🐨'];

function mascotHtml(avatar, sizePx){
  if(avatar === CYBORG_KEY){
    return `<img src="${CYBORG_SRC}" style="height:${sizePx}px">`;
  }
  return avatar;
}

const LEADERBOARD_SEED = [
  { nick:'DataDrivenKate', avatar:'🦉', score: 640 },
  { nick:'AutomationMartin', avatar:'🦁', score: 560 },
  { nick:'PromptPilot', avatar:'🐼', score: 470 },
  { nick:'WorkflowGreg', avatar:'🐸', score: 360 },
  { nick:'FirstPilotRun', avatar:'🐧', score: 250 },
];
let leaderboard = [...LEADERBOARD_SEED];

const app = document.getElementById('widget');

function toast(msg){
  const t = document.createElement('div');
  t.style.position='absolute'; t.style.top='14px'; t.style.left='50%';
  t.style.transform='translateX(-50%)'; t.style.background='var(--ink)'; t.style.color='#fff';
  t.style.fontWeight='700'; t.style.fontSize='13px'; t.style.padding='8px 16px'; t.style.borderRadius='999px';
  t.style.zIndex='20'; t.textContent = msg;
  app.appendChild(t);
  setTimeout(()=> t.remove(), 1200);
}

function confettiBurst(){
  const wrap = document.createElement('div');
  wrap.className='confetti';
  const bits = ['🎉','✨','🎊','⭐','🟡','🟣'];
  for(let i=0;i<24;i++){
    const s = document.createElement('span');
    s.textContent = bits[Math.floor(Math.random()*bits.length)];
    s.style.left = Math.random()*100+'%';
    s.style.animationDuration = (1.4+Math.random()*1.2)+'s';
    s.style.animationDelay = (Math.random()*.4)+'s';
    wrap.appendChild(s);
  }
  app.appendChild(wrap);
  setTimeout(()=>wrap.remove(), 2600);
}

const OBSTACLES = [
  { emoji:'🚫', label:'change resistance' },
  { emoji:'🗑️', label:'messy data' },
  { emoji:'🔒', label:'siloed systems' },
  { emoji:'❓', label:'no clear use case' },
  { emoji:'⚠️', label:'compliance risk' },
];
const COLLECT_GROUND = [
  { emoji:'📊', value:10, label:'clean data' },
  { emoji:'🎓', value:15, label:'team training' },
];
const COLLECT_AIR = [
  { emoji:'⚡', value:30, label:'automated workflow' },
  { emoji:'🤖', value:25, label:'AI copilot' },
];

function ctaFor(score, won){
  if(won || score>=550) return {
    head: 'You cleared the blockers in the game. Now do it for real.',
    body: 'Turn that momentum into an actual plan. See how ready you are for AI in your business.',
    btn: 'Take the AI Readiness Assessment →'
  };
  if(score>=250) return {
    head: 'Good run — but the blockers slowed you down.',
    body: 'The same gaps stall real businesses. Two short assessments pinpoint what stands between where your business is now and where systems, strategy and AI could take it — start with whichever fits you.',
    btn: 'Start the assessment →'
  };
  return {
    head: 'The blockers won this round.',
    body: "Presence isn't the problem — architecture is. The Presence-to-Profit Assessment finds where your offer or funnel leaks revenue, which systems are missing for consistent conversion, and your next concrete step beyond making more content.",
    btn: 'Take the Presence-to-Profit Assessment →'
  };
}

function badgeFor(score){
  if(score>=550) return 'AI Implementation Master 🏆';
  if(score>=400) return 'Rollout Expert 🥇';
  if(score>=250) return 'Pilot Project Pro 🥈';
