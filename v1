  .footer-links{ display:flex; justify-content:center; gap:14px; margin-top:14px; }
  .footer-links a{ font-size:12px; color:var(--ink-soft); text-decoration:none; }

  .confetti{ position:absolute; inset:0; pointer-events:none; overflow:hidden; z-index:5; }
  .confetti span{ position:absolute; top:-10%; font-size:16px; animation:fall linear forwards; }
  @keyframes fall{ to{ transform:translateY(700px) rotate(360deg); opacity:0; } }

  .cta-card{ width:100%; margin:14px 0 4px; padding:16px 14px; border-radius:16px; text-align:center;
    background:linear-gradient(150deg, #E9F3F2, #F7ECEC); border:1px solid var(--line); }
  .cta-head{ font-family:'Baloo 2',sans-serif; font-weight:800; font-size:16px; line-height:1.3;
