  canvas{ width:100%; display:block; border-radius:18px; touch-action:none;
    background:
      linear-gradient(rgba(243,233,233,.58), rgba(225,206,206,.52)),
      url("data:image/jpeg;base64,") center 60%/cover no-repeat;
