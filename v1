}

/* =========================================================
   SCREENS
   ========================================================= */

function renderStart(){
  app.innerHTML = `
    <div class="screen" style="align-items:center; text-align:center; justify-content:center;">
      <span class="mascot">${mascotHtml(CYBORG_KEY, 84)}</span>
      <h1>AI Implementation Run</h1>
      <p class="muted" style="margin-top:8px;">Drive AI adoption across the business: dodge the blockers that derail rollouts, and collect the data, training and quick wins that make it stick. Reach full adoption before momentum runs out!</p>
      <div class="legend-block">
        <div class="legend-title danger-title">Avoid these blockers</div>
        <div class="legend-grid">
          ${OBSTACLES.map(o=>`<span><i>${o.emoji}</i>${o.label}</span>`).join('')}
        </div>
      </div>
      <div class="legend-block">
        <div class="legend-title good-title">Collect these wins</div>
        <div class="legend-grid">
          ${[...COLLECT_GROUND, ...COLLECT_AIR].map(c=>`<span><i>${c.emoji}</i>${c.label} <b>+${c.value}</b></span>`).join('')}
        </div>
      </div>
      <div class="legend"><span>❤️❤️❤️ 3 lives</span></div>
      <div class="btn-row" style="width:100%;">
        <button class="btn" id="goCreate" style="flex:1;">Play now</button>
