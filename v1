function renderAvatar(){
  app.innerHTML = `
    <div class="screen">
      <h2>Create your character</h2>
      <p class="muted">Pick a nickname and the avatar you'll run with.</p>
      <label>Your nickname</label>
      <input type="text" id="nickInput" maxlength="16" placeholder="e.g. AutomationAce" value="${state.nick}">
      <label>Choose an avatar</label>
      <div class="avatar-grid" id="avatarGrid">
        <div class="avatar-opt img-opt ${state.avatar===CYBORG_KEY?'selected':''}" data-a="${CYBORG_KEY}"><img src="${CYBORG_SRC}" alt="Cyborg"></div>
        ${AVATARS.map(a=>`<div class="avatar-opt ${a===state.avatar?'selected':''}" data-a="${a}">${a}</div>`).join('')}
      </div>
      <label>E-mail address</label>
      <input type="email" id="emailInput" placeholder="you@company.com" value="${state.email}">
      <p class="small-note">We use your e-mail to save your score and send your result.</p>

      <div class="consent">
        <label class="consent-row">
          <input type="checkbox" id="consentPrivacy" ${state.consentPrivacy?'checked':''}>
          <span>I agree that ${CONFIG.COMPANY} may store my e-mail and nickname to save my score and send me my result. <span class="req">*</span>
          <a href="${CONFIG.PRIVACY_URL}" target="_blank" rel="noopener">Privacy policy</a></span>
        </label>
        <label class="consent-row">
          <input type="checkbox" id="consentMarketing" ${state.consentMarketing?'checked':''}>
          <span>I'd also like to receive occasional e-mails about AI implementation tips and services. <em>(optional)</em></span>
        </label>
        <p class="small-note" style="text-align:left; margin-top:8px;">
          You can withdraw consent at any time via the unsubscribe link in any e-mail, or by contacting us. Withdrawing does not affect processing carried out before withdrawal.
        </p>
      </div>

      <div class="btn-row">
        <button class="btn secondary" id="backStart">Back</button>
        <button class="btn" id="startGame" disabled>Start run</button>
      </div>
    </div>`;

  const nickInput = document.getElementById('nickInput');
  const emailInput = document.getElementById('emailInput');
  const startBtn = document.getElementById('startGame');
  const cPrivacy = document.getElementById('consentPrivacy');
  const cMarketing = document.getElementById('consentMarketing');

  function validate(){
    const okNick = nickInput.value.trim().length >= 2;
    const okEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim());
    startBtn.disabled = !(okNick && okEmail && cPrivacy.checked);
  }
  nickInput.oninput = validate;
  emailInput.oninput = validate;
  cPrivacy.onchange = validate;
  cMarketing.onchange = validate;
  validate();

  document.getElementById('avatarGrid').onclick = (e)=>{
    const opt = e.target.closest('.avatar-opt');
    if(!opt) return;
    state.avatar = opt.dataset.a;
    document.querySelectorAll('.avatar-opt').forEach(el=>el.classList.remove('selected'));
    opt.classList.add('selected');
  };

  document.getElementById('backStart').onclick = ()=>{ state.screen='start'; render(); };
  document.getElementById('startGame').onclick = ()=>{
    state.nick = nickInput.value.trim();
    state.email = emailInput.value.trim();
    state.consentPrivacy = cPrivacy.checked;
    state.consentMarketing = cMarketing.checked;
    // Store the exact wording agreed to + timestamp = GDPR proof of consent
    state.consentTextShown = cPrivacy.parentElement.innerText.trim()
      + (cMarketing.checked ? ' || MARKETING: ' + cMarketing.parentElement.innerText.trim() : '');
    state.consentTimestamp = new Date().toISOString();
    subscribeToMailchimp();
    state.score = 0;
    state._saved = false;
    state.screen='play';
    render();
  };
}

/* ---------------- MAILCHIMP SUBSCRIBE ----------------
   Uses Mailchimp's JSONP endpoint so it works from a static
   page with no backend and no API key exposed.
   Requires CONFIG.MAILCHIMP_ACTION to be set (see top of file).
   Recommended: enable DOUBLE OPT-IN in your Mailchimp audience.
   ---------------------------------------------------------
   Merge fields to create in Mailchimp (Audience > Settings >
   Audience fields and *|MERGE|* tags):
     NICK      (text)  - player nickname
     CONSENTTS (text)  - consent timestamp, ISO 8601
     CONSENTTX (text)  - exact consent wording shown
   Marketing consent is sent as a Mailchimp GDPR/interest flag
   via MARKETING (text: yes/no) so you can segment on it.
   ----------------------------------------------------------- */
function subscribeToMailchimp(){
  if(!CONFIG.MAILCHIMP_ACTION){
    console.warn('[AI Implementation Run] CONFIG.MAILCHIMP_ACTION is empty - e-mail not sent. Add your Mailchimp URL at the top of this file.');
    return;
  }
  if(!state.consentPrivacy) return; // never send without required consent

  const params = new URLSearchParams({
    EMAIL: state.email,
    NICK: state.nick,
    CONSENTTS: state.consentTimestamp,
    CONSENTTX: state.consentTextShown.slice(0, 240),
    MARKETING: state.consentMarketing ? 'yes' : 'no',
  });

  const cb = 'mcCallback_' + Date.now();
  window[cb] = (res)=>{
    if(res && res.result === 'error'){
      console.warn('[Mailchimp]', res.msg);
    }
    delete window[cb];
    if(s.parentNode) s.parentNode.removeChild(s);
  };

  const sep = CONFIG.MAILCHIMP_ACTION.includes('?') ? '&' : '?';
  const s = document.createElement('script');
  s.src = CONFIG.MAILCHIMP_ACTION + sep + params.toString() + '&c=' + cb;
  s.onerror = ()=>{ console.warn('[Mailchimp] request failed'); delete window[cb]; };
  document.body.appendChild(s);
}

/* ---------------- GAME (canvas runner) ---------------- */

const CANVAS_W = 412, CANVAS_H = 300;
const GROUND_Y = 235;
const GRAVITY = 0.9;
const JUMP_V = -15;
const PLAYER_X = 55;
const PLAYER_SIZE = 38;
const FINISH_DISTANCE = 3200;



let g = null; // current run state object
let rafId = null;
let lastT = 0;
let keyHandlerAttached = false;

function resetRun(){
  g = {
    speed: 4.2,
    distance: 0,
    lives: 3,
    coinScore: 0,
    invuln: 0,
    over: false,
    result: null, // 'finish' | 'gameover'
    spawnTimer: 40,
    entities: [],
    particles: [],
    player: { y: GROUND_Y - PLAYER_SIZE, vy: 0, jumping:false, blink:0 },
  };
}

function jump(){
  if(!g || g.over) return;
  if(!g.player.jumping){
    g.player.vy = JUMP_V;
    g.player.jumping = true;
  }
}

function attachControlsOnce(){
  if(keyHandlerAttached) return;
  keyHandlerAttached = true;
  window.addEventListener('keydown', (e)=>{
    if(state.screen !== 'play') return;
    if(e.code === 'Space' || e.code === 'ArrowUp'){
      e.preventDefault();
      jump();
    }
  });
}

function renderPlay(){
  app.innerHTML = `
    <div class="screen">
      <div class="hud">
        <div class="coin"><span class="dot">🪙</span> <span id="scoreVal">0</span> pts</div>
        <div class="lives" id="livesVal">❤️❤️❤️</div>
      </div>
      <div class="progress-track"><div id="distFill" style="width:0%"></div></div>
      <canvas id="game" width="${CANVAS_W}" height="${CANVAS_H}"></canvas>
      <p class="hint">Space / arrow up / tap the screen = jump</p>
    </div>`;

  attachControlsOnce();
  resetRun();

  const canvas = document.getElementById('game');
  const ctx = canvas.getContext('2d');
  canvas.addEventListener('pointerdown', (e)=>{ e.preventDefault(); jump(); });

  const scoreEl = document.getElementById('scoreVal');
  const livesEl = document.getElementById('livesVal');
  const distEl = document.getElementById('distFill');

  function spawnEntity(){
    const roll = Math.random();
    if(roll < 0.42){
      const def = OBSTACLES[Math.floor(Math.random()*OBSTACLES.length)];
      g.entities.push({ type:'obstacle', emoji:def.emoji, x: CANVAS_W + 20, y: GROUND_Y - 34, w:34, h:34 });
    } else if(roll < 0.72){
      const def = COLLECT_GROUND[Math.floor(Math.random()*COLLECT_GROUND.length)];
      g.entities.push({ type:'collect', emoji:def.emoji, value:def.value, x: CANVAS_W + 20, y: GROUND_Y - 30, w:28, h:28 });
    } else {
      const def = COLLECT_AIR[Math.floor(Math.random()*COLLECT_AIR.length)];
      g.entities.push({ type:'collect', emoji:def.emoji, value:def.value, x: CANVAS_W + 20, y: GROUND_Y - 105, w:30, h:30 });
    }
    g.spawnTimer = 46 + Math.random()*30;
  }

  function overlap(px,py,pw,ph, ex,ey,ew,eh){
    return px < ex+ew && px+pw > ex && py < ey+eh && py+ph > ey;
  }

  function endRun(result){
    if(g.over) return;
    g.over = true;
    g.result = result;
    stopLoop();
    const bonus = result === 'finish' ? 150 + g.lives*30 : g.lives*20;
    state.score = g.coinScore + bonus;
    setTimeout(()=>{ state.screen='result'; render(); }, 350);
  }

  function update(dt){
    if(g.over) return;
    // predkosc rosnie z dystansem
    g.speed = Math.min(9, 4.2 + g.distance/1400);
    g.distance += g.speed * dt;

    // fizyka gracza
    const p = g.player;
    p.vy += GRAVITY * dt;
    p.y += p.vy * dt;
    if(p.y >= GROUND_Y - PLAYER_SIZE){
      p.y = GROUND_Y - PLAYER_SIZE;
      p.vy = 0;
      p.jumping = false;
    }
    if(g.invuln > 0) g.invuln -= dt;

    // spawn
    g.spawnTimer -= dt;
    if(g.spawnTimer <= 0) spawnEntity();

    // ruch encji + kolizje
    for(let i=g.entities.length-1; i>=0; i--){
      const e = g.entities[i];
      e.x -= g.speed * dt * 1.6;
      const hit = overlap(PLAYER_X, p.y, PLAYER_SIZE, PLAYER_SIZE, e.x, e.y, e.w, e.h);
      if(hit){
        if(e.type === 'obstacle'){
          if(g.invuln <= 0){
            g.lives -= 1;
            g.invuln = 70;
            g.entities.splice(i,1);
            if(g.lives <= 0){ endRun('gameover'); }
            continue;
          }
        } else {
          g.coinScore += e.value;
          g.particles.push({ x:e.x, y:e.y, life:36, text:'+'+e.value });
          g.entities.splice(i,1);
          continue;
        }
      }
      if(e.x + e.w < -10) g.entities.splice(i,1);
    }

    // particles (+N)
    for(let i=g.particles.length-1;i>=0;i--){
      const pt = g.particles[i];
      pt.y -= 0.6*dt; pt.life -= dt;
      if(pt.life<=0) g.particles.splice(i,1);
    }

    if(g.distance >= FINISH_DISTANCE){ endRun('finish'); }
  }

  function drawGround(){
    ctx.strokeStyle = '#9FBFBE';
    ctx.lineWidth = 2;
    ctx.setLineDash([8,7]);
    ctx.beginPath();
    ctx.moveTo(0, GROUND_Y+2);
    ctx.lineTo(CANVAS_W, GROUND_Y+2);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  function draw(){
    ctx.clearRect(0,0,CANVAS_W,CANVAS_H);
    drawGround();

    // player
    const p = g.player;
    ctx.save();
    if(g.invuln > 0 && Math.floor(g.invuln/6)%2===0){ ctx.globalAlpha = 0.35; }
    if(state.avatar === CYBORG_KEY && cyborgImg.complete && cyborgImg.naturalWidth > 0){
      const drawH = PLAYER_SIZE * 1.95;
      const drawW = drawH * (cyborgImg.naturalWidth / cyborgImg.naturalHeight);
      const dx = PLAYER_X + PLAYER_SIZE/2 - drawW/2;
      const dy = (p.y + PLAYER_SIZE) - drawH;
      ctx.drawImage(cyborgImg, dx, dy, drawW, drawH);
    } else {
      ctx.font = (PLAYER_SIZE)+'px sans-serif';
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(state.avatar === CYBORG_KEY ? '🤖' : state.avatar, PLAYER_X + PLAYER_SIZE/2, p.y + PLAYER_SIZE/2);
    }
    ctx.restore();

    // entities
    g.entities.forEach(e=>{
      ctx.font = (e.h)+'px sans-serif';
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(e.emoji, e.x + e.w/2, e.y + e.h/2);
    });

    // particles
    ctx.font = 'bold 13px Manrope, sans-serif';
    ctx.fillStyle = '#036564';
    g.particles.forEach(pt=>{
      ctx.globalAlpha = Math.max(0, pt.life/36);
      ctx.fillText(pt.text, pt.x, pt.y);
    });
    ctx.globalAlpha = 1;

    scoreEl.textContent = g.coinScore;
    livesEl.textContent = '❤️'.repeat(Math.max(0,g.lives)) + '🖤'.repeat(3-Math.max(0,g.lives));
    distEl.style.width = Math.min(100, (g.distance/FINISH_DISTANCE)*100)+'%';
  }

  function loop(t){
    const dt = Math.min((t - lastT)/16.6667, 2.2);
    lastT = t;
    update(dt);
    draw();
    if(!g.over) rafId = requestAnimationFrame(loop);
  }

  lastT = performance.now();
  rafId = requestAnimationFrame(loop);
}

function stopLoop(){
  if(rafId){ cancelAnimationFrame(rafId); rafId = null; }
}

/* ---------------- RESULT ---------------- */
function renderResult(){
  if(!state._saved){
    leaderboard.push({ nick: state.nick || 'Player', avatar: state.avatar, score: state.score });
    leaderboard.sort((a,b)=>b.score-a.score);
    state._saved = true;
  }
  const won = g && g.result === 'finish';
  app.innerHTML = `
    <div class="screen" style="align-items:center; text-align:center; justify-content:center;">
      <span class="mascot">${mascotHtml(state.avatar, 72)}</span>
      <h1>${won ? 'AI is live across the business!' : 'The rollout stalled...'}</h1>
      <p class="muted">${won ? 'You drove the implementation all the way to full adoption.' : 'The blockers won this time, but give it another go!'}</p>
      <div class="badge">${badgeFor(state.score)}</div>
      <div class="coin" style="font-size:21px; margin-bottom:6px; display:flex; align-items:center; gap:6px; justify-content:center; font-family:'Baloo 2',sans-serif; font-weight:800; color:var(--brand-dark);">
        <span style="width:22px;height:22px;border-radius:50%;background:var(--gold);display:inline-flex;align-items:center;justify-content:center;font-size:12px;">🪙</span> ${state.score} pts
      </div>
      <div class="cta-card">
        <div class="cta-head">${ctaFor(state.score, won).head}</div>
        <p class="cta-body">${ctaFor(state.score, won).body}</p>
        <a class="btn cta-btn" href="${CONFIG.ASSESSMENT_URL}" target="_blank" rel="noopener" id="ctaRoadmap">${ctaFor(state.score, won).btn}</a>
        <div class="cta-note">Two short assessments · free · no payment required</div>
      </div>
      <div class="btn-row" style="width:100%;">
        <button class="btn secondary" id="playAgain">Play again</button>
        <button class="btn" id="seeLb">View leaderboard</button>
      </div>
    </div>`;
  if(won) confettiBurst();
  document.getElementById('playAgain').onclick = ()=>{ state.screen='play'; render(); };
  document.getElementById('seeLb').onclick = ()=>{ state.screen='leaderboard'; render(); };
}

function renderLeaderboard(){
  const rows = leaderboard.slice(0,10).map((p,i)=>{
    const isMe = state._saved && p.nick===state.nick && p.score===state.score && p.avatar===state.avatar;
    return `<tr class="${isMe?'me':''}">
      <td class="rank">${i+1}</td>
      <td style="display:flex; align-items:center; gap:6px;">${mascotHtml(p.avatar, 18)} <span>${p.nick}${isMe?' (You)':''}</span></td>
      <td class="pts">${p.score}</td>
    </tr>`;
  }).join('');
  app.innerHTML = `
    <div class="screen">
      <h2 style="text-align:center;">🏆 Player leaderboard</h2>
      <p class="muted" style="text-align:center;">Top scores from this demo session.</p>
      <table class="lb">${rows}</table>
      <div class="btn-row">
        <button class="btn secondary" id="backHome">Home</button>
        <button class="btn" id="playAgain2">Play</button>
      </div>
    </div>`;
  document.getElementById('backHome').onclick = ()=>{ state.screen='start'; render(); };
  document.getElementById('playAgain2').onclick = ()=>{ state.screen='avatar'; render(); };
}

function render(){
  stopLoop();
  if(state.screen==='start') renderStart();
  else if(state.screen==='avatar') renderAvatar();
  else if(state.screen==='play') renderPlay();
  else if(state.screen==='result') renderResult();
  else if(state.screen==='leaderboard') renderLeaderboard();
}

render();
</script>
</body>
