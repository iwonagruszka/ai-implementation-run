  .hint{ text-align:center; font-size:12px; color:var(--ink-soft); margin-top:8px; }

  .badge{
    font-family:'Baloo 2',sans-serif; font-weight:800; font-size:21px; text-align:center;
    background:linear-gradient(135deg, var(--brand), #05807E); color:#FFFFFF;
    padding:15px; border-radius:18px; margin:10px 0;
