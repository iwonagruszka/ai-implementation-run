  .cta-body{ font-size:12.5px; line-height:1.5; color:var(--ink-soft); font-weight:600; margin:0 0 12px; }
  .cta-btn{ display:block; text-decoration:none; text-align:center; }
  .cta-note{ font-size:10.5px; color:var(--ink-soft); opacity:.85; font-weight:700; margin-top:7px; }
  .consent{ margin-top:12px; padding:12px; background:#FBF6F6; border:1px solid var(--line); border-radius:12px; }
  .consent-row{ display:flex; align-items:flex-start; gap:9px; margin-bottom:10px; cursor:pointer;
