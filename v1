  table.lb{ width:100%; border-collapse:collapse; margin-top:8px; }
  table.lb td{ padding:9px 6px; border-bottom:1px solid #EDE0E0; font-size:14px; }
  table.lb tr.me{ background:#DCEDEC; font-weight:800; border-radius:10px; }
